APP_NAME='Inventario Uniguajira'
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO
SEDE=Maicao

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=tenant
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=inventario_maicao
DB_CENTRAL_DATABASE=inventario_central
DB_USERNAME=root
DB_PASSWORD=

# ─── Multi-Tenant / Multi-Sede ──────────────────────────────────
TENANCY_CENTRAL_CONNECTION=central
TENANCY_DB_PREFIX=inventario_
TENANCY_DEFAULT_TENANT=
TENANCY_RESOLUTION=subdomain
TENANCY_BASE_DOMAIN=localhost
TENANCY_CENTRAL_DOMAIN=
# Credenciales por sede (hosting compartido)
TENANT_DB_HOST=localhost
TENANT_DB_PORT=3306
TENANT_MAICAO_DATABASE=
TENANT_MAICAO_USERNAME=
TENANT_MAICAO_PASSWORD=
TENANT_VILLANUEVA_DATABASE=
TENANT_VILLANUEVA_USERNAME=
TENANT_VILLANUEVA_PASSWORD=
TENANT_FONSECA_DATABASE=
TENANT_FONSECA_USERNAME=
TENANT_FONSECA_PASSWORD=
# ────────────────────────────────────────────────────────────────

SESSION_DRIVER=database
SESSION_CONNECTION=central
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
