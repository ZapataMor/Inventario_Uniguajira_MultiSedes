# ================================ LOCAL =================================
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
LOG_LEVEL=debug

DB_CONNECTION=tenant
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=inv_maicao
DB_CENTRAL_DATABASE=inventario_central
DB_USERNAME=root
DB_PASSWORD=

TENANCY_DEFAULT_TENANT=maicao
TENANCY_RESOLUTION=session
TENANCY_BASE_DOMAIN=localhost
TENANCY_CENTRAL_DOMAIN=

TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=3306
TENANT_MAICAO_DATABASE=inv_maicao
TENANT_MAICAO_USERNAME=root
TENANT_MAICAO_PASSWORD=
TENANT_VILLANUEVA_DATABASE=inv_villanueva
TENANT_VILLANUEVA_USERNAME=root
TENANT_VILLANUEVA_PASSWORD=
TENANT_FONSECA_DATABASE=inv_fonseca
TENANT_FONSECA_USERNAME=root
TENANT_FONSECA_PASSWORD=

SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
